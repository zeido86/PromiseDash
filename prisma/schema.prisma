// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  username          String?         @unique
  name              String?
  email             String          @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  habits            Habit[]
  habitEntries      HabitEntry[]
  weightProfile     WeightProfile?
  weightEntries     WeightEntry[]
  calorieProfile    CalorieProfile?
  calorieEntries    CalorieEntry[]
  calorieBalances   CalorieBalance[]
  categories        Category[]
  challengesSent    Challenge[]     @relation("ChallengeChallenger")
  challengesReceived Challenge[]    @relation("ChallengeChallenged")
  accounts          Account[]
  sessions          Session[]
}

model Challenge {
  id           String          @id @default(cuid())
  challengerId String
  challengedId String
  habitTitle   String          @default("Utmaning")
  endDate      DateTime        @default(now())
  status       ChallengeStatus @default(PENDING)
  message      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  challenger   User            @relation("ChallengeChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged   User            @relation("ChallengeChallenged", fields: [challengedId], references: [id], onDelete: Cascade)
  habits       Habit[]

  @@index([challengerId, status])
  @@index([challengedId, status])
}

model Habit {
  id               String            @id @default(cuid())
  userId           String
  categoryId       String?
  challengeId      String?
  title            String
  description      String?
  templateType     HabitTemplateType @default(STANDARD)
  trackingType     HabitTrackingType @default(BOOLEAN)
  metricLabel      String?
  goalLabel        String?
  goalComparator   GoalComparator?
  frequencyType    HabitFrequencyType
  scheduleMode     HabitScheduleMode @default(FLEXIBLE)
  weeklyTarget     Int?
  weekdays         Int[]             @default([])
  startValue       Float?
  targetValue      Float?
  milestonesEnabled Boolean          @default(false)
  milestoneStep    Float?
  unit             String?
  startDate        DateTime
  endDate          DateTime?
  status           HabitStatus       @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  challenge        Challenge?        @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  entries          HabitEntry[]

  @@index([challengeId])
}

model HabitEntry {
  id            String   @id @default(cuid())
  habitId        String
  userId         String
  date           DateTime
  checked        Boolean?
  numericValue   Float?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  habit          Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
}

model Category {
  id           String   @id @default(cuid())
  userId       String
  name         String
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits       Habit[]

  @@unique([userId, name])
}

model WeightProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  startWeight      Float
  weighInWeekday   Int      @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeightEntry {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  weight      Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model CalorieProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  dailyTarget      Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalorieEntry {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  intake          Int
  burn            Int      @default(0)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model CalorieBalance {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime
  dailyDelta        Int
  runningBalance    Int
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum HabitTrackingType {
  BOOLEAN
  NUMERIC
}

enum HabitFrequencyType {
  DAILY
  WEEKDAYS
  WEEKLY_TARGET
  WEEKLY
}

enum HabitStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum GoalComparator {
  GTE
  LTE
  EQ
}

enum HabitScheduleMode {
  FIXED
  FLEXIBLE
}

enum HabitTemplateType {
  STANDARD
  GRAPH
  BANK
  COUNTDOWN
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}
